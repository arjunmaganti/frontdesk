# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_personal_telegram_chat_id_here
BUSINESS_NAME="Your Business Name"
AGENT_NAME="Your Agent Name"

# LLM Provider Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL_NAME=gemini-1.5-flash # Default cost-effective Gemini model

# Cost Protection & Spam Guardrails
DAILY_MESSAGE_CAP=200       # Maximum AI messages processed for this tenant per day
USER_RATE_LIMIT=5          # Max messages a visitor can send per window
USER_RATE_WINDOW=60        # Rate limit window in seconds (60s)

# Web Crawler Integration (Build-Time Sync)
# Set WEBSITE_URL to automatically crawl and update markdown documents before every build
# WEBSITE_URL=https://example-business.com/
